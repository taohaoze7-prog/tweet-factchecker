{
  "manifest_version": 3,
  "name": "Tweet FactChecker",
  "version": "0.1.0",
  "description": "在 X/Twitter 时间线上一键核查推文断言。",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
